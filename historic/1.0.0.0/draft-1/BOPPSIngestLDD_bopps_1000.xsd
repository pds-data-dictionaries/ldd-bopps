  <xs:complexType name="gondola_latitude">
    <xs:annotation>
      <xs:documentation> The latitude of the gondola reported by the
        on-board GPS receiver in degrees. </xs:documentation>
    </xs:annotation>
    <xs:simpleContent>
      <xs:extension base="bopps:gondola_latitude_WO_Units">
