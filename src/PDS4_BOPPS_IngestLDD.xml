	<DD_Attribute>
		<name>product_type</name>
		<version_id>1.0</version_id>
		<local_identifier>product_type</local_identifier>
		<nillable_flag>false</nillable_flag>
		<submitter_name>Raymond Espiritu; Anne Raugh (ed.)</submitter_name>
		<definition>
			The type of product generated: RAW, BIAS_SUBTRACTED, CALIBRATED, SHIFTED, COADDED, FLATFIELD, RELAYS, TEMPS
    	</definition>

		<DD_Value_Domain>
			<enumeration_flag>true</enumeration_flag>
			<value_data_type>ASCII_Short_String_Collapsed</value_data_type>

			<DD_Permissible_Value>
				<value>RAW</value>
				<value_meaning>Denotes the product as the raw single frame image. In a raw single frame image lower DN values
				indicate more signal.</value_meaning>
			</DD_Permissible_Value>

			<DD_Permissible_Value>
				<value>BIAS_SUBTRACTED</value>
				<value_meaning>Denotes the product as the result of the signal frame subtracted from the bias frame. This
				ordering of the subtraction results in an image where higher DN values indicate more signal.</value_meaning>
			</DD_Permissible_Value>

			<DD_Permissible_Value>
				<value>CALIBRATED</value>
				<value_meaning>Denotes the product as a bias subtracted image that has been calibrated.</value_meaning>
			</DD_Permissible_Value>

			<DD_Permissible_Value>
				<value>SHIFTED</value>
				<value_meaning>Denotes the product as the summed average of a sequence of calibrated images that have been
				shifted in pixel space such that each pixel is spatially co-located to the same region of the sky.</value_meaning>
			</DD_Permissible_Value>

			<DD_Permissible_Value>
				<value>COADDED</value>
				<value_meaning>Denotes the product as the summed average of a sequence of calibrated images without being shifted
				in pixel space.</value_meaning>
			</DD_Permissible_Value>
			
			<DD_Permissible_Value>
				<value>FLATFIELD</value>
				<value_meaning>The associated product contains a flat field observation.</value_meaning>
			</DD_Permissible_Value>
			
			<DD_Permissible_Value>
				<value>RELAYS</value>
				<value_meaning>Product is an ASCII table containing relay and cyro cooler pressure reported by the BIRC instrument.
				</value_meaning>
			</DD_Permissible_Value>

			<DD_Permissible_Value>
				<value>TEMPS</value>
				<value_meaning>Product is an ASCII table containing the temperature values reported by the BIRC instrument.
				</value_meaning>
			</DD_Permissible_Value>
			

		</DD_Value_Domain>
	</DD_Attribute>

