        frames created by a single start_observation command.
        </xs:documentation>
    </xs:annotation>
    <xs:restriction base="pds:ASCII_Short_String_Collapsed">
    	<xs:pattern value='[0-9]{10}.[0-9]{6}'/>
     <xs:minLength value="17"/>
